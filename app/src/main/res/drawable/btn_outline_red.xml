<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle"><solid android:color="#fff5f5"/><stroke android:width="2dp" android:color="#d63031"/><corners android:radius="14dp"/></shape>
    </item>
    <item>
        <shape android:shape="rectangle"><solid android:color="#ffffff"/><stroke android:width="2dp" android:color="#fecdcd"/><corners android:radius="14dp"/></shape>
    </item>
</selector>
