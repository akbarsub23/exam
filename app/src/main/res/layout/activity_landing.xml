<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@drawable/bg_landing" android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:paddingHorizontal="20dp" android:paddingBottom="28dp">

        <androidx.cardview.widget.CardView android:id="@+id/cardMain"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            app:cardCornerRadius="26dp" app:cardElevation="12dp"
            app:cardBackgroundColor="@color/card_white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:paddingHorizontal="22dp"
                android:paddingTop="28dp" android:paddingBottom="24dp">

                <!-- Logo -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:layout_marginBottom="18dp">
                    <FrameLayout android:layout_width="108dp" android:layout_height="108dp" android:layout_gravity="center">
                        <View android:layout_width="108dp" android:layout_height="108dp" android:background="@drawable/ring_gradient"/>
                        <ImageView android:layout_width="94dp" android:layout_height="94dp"
                            android:layout_gravity="center" android:src="@drawable/logo_sekolah"
                            android:background="@drawable/circle_white" android:clipToOutline="true" android:scaleType="centerCrop"/>
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SMK Negeri 1 Gempol" android:textSize="19sp" android:textStyle="bold"
                        android:textColor="@color/blue_deep" android:layout_marginTop="12dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PASURUAN · JAWA TIMUR" android:textSize="10sp"
                        android:textColor="@color/blue_mid" android:letterSpacing="0.1" android:layout_marginTop="2dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="  ★  Computer Based Test  ★  " android:textSize="10sp"
                        android:textColor="@color/white" android:background="@drawable/bg_badge"
                        android:paddingHorizontal="14dp" android:paddingVertical="4dp" android:layout_marginTop="10dp"/>
                </LinearLayout>

                <!-- Divider -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                    <View android:layout_width="0dp" android:layout_height="1.5dp"
                        android:layout_weight="1" android:background="@drawable/divider_h"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="  Pilih Jaringan  " android:textSize="10sp"
                        android:textStyle="bold" android:textColor="@color/blue_mid"/>
                    <View android:layout_width="0dp" android:layout_height="1.5dp"
                        android:layout_weight="1" android:background="@drawable/divider_h_rev"/>
                </LinearLayout>

                <!-- Network Local -->
                <androidx.cardview.widget.CardView android:id="@+id/cardLocal"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp" app:cardCornerRadius="14dp"
                    app:cardElevation="0dp" app:cardBackgroundColor="@color/blue_pale"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp">
                        <RadioButton android:id="@+id/radioLocal" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:checked="true"
                            android:buttonTint="@color/blue_mid"/>
                        <FrameLayout android:layout_width="40dp" android:layout_height="40dp"
                            android:background="@drawable/icon_bg_blue" android:layout_marginStart="10dp">
                            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                                android:layout_gravity="center" android:src="@drawable/ic_lan"/>
                        </FrameLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Jaringan Lokal" android:textSize="14sp"
                                android:textStyle="bold" android:textColor="@color/blue_deep"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="192.168.1.100" android:textSize="12sp" android:textColor="@color/gray_text"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Network Online -->
                <androidx.cardview.widget.CardView android:id="@+id/cardOnline"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp" app:cardCornerRadius="14dp"
                    app:cardElevation="0dp" app:cardBackgroundColor="@color/gray_soft"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp">
                        <RadioButton android:id="@+id/radioOnline" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:checked="false"
                            android:buttonTint="@color/blue_mid"/>
                        <FrameLayout android:layout_width="40dp" android:layout_height="40dp"
                            android:background="@drawable/icon_bg_red" android:layout_marginStart="10dp">
                            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                                android:layout_gravity="center" android:src="@drawable/ic_globe"/>
                        </FrameLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Jaringan Online" android:textSize="14sp"
                                android:textStyle="bold" android:textColor="@color/blue_deep"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="lms.semakinpol.my.id" android:textSize="12sp" android:textColor="@color/gray_text"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ✅ Tombol BUKA — satu Button langsung, teks putih -->
                <Button android:id="@+id/btnMasuk"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Buka"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/btn_primary"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

                <!-- Hidden views agar binding tidak error -->
                <ProgressBar android:id="@+id/btnMasukProgress"
                    android:layout_width="1dp" android:layout_height="1dp"
                    android:visibility="gone"/>
                <TextView android:id="@+id/btnMasukText"
                    android:layout_width="1dp" android:layout_height="1dp"
                    android:visibility="gone"/>

                <!-- ✅ Tombol KELUAR — background merah, teks putih -->
                <Button android:id="@+id/btnKeluar"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Keluar"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/btn_keluar_red"
                    android:layout_marginTop="10dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="© 2025 SMK Negeri 1 Gempol · CBT System"
            android:textSize="10sp" android:textColor="#94a3b8" android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/cardMain"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
